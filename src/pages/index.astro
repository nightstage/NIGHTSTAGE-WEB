---
import heroVideoMp4 from "../../assets/video/nightstage-hero-1080.mp4";
import heroVideoWebm from "../../assets/video/nightstage-hero-4k.webm";

const title = "DJ para eventos en Madrid | Bodas y empresas | NIGHTSTAGE";
const description =
  "DJ para eventos en Madrid: bodas, empresas y fiestas privadas. Sonido, iluminacion y cabina profesional. Consulta disponibilidad: 685 221 949.";
const siteUrl = "https://nightstage-es.com/";
const businessName = "NIGHTSTAGE";
const phone = "685 221 949";
const phoneHref = "tel:+34685221949";
const phoneInternational = "+34685221949";
const streetAddress = "Calle de Alcantara, 19";
const addressLocality = "Madrid";
const addressRegion = "Comunidad de Madrid";
const postalCode = "28006";
const address = `${streetAddress}, Salamanca, ${postalCode} ${addressLocality}`;
const email = "info@nightstage-es.com";
const emailHref = `mailto:${email}`;
const year = new Date().getFullYear();
const youtubeId = "xnsxllY5VPw";
const heroPoster = `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`;
const googleMapsReviewsUrl =
  "https://www.google.com/maps/place/NIGHT+STAGE/@40.4275766,-3.6765617,17z/data=!4m8!3m7!1s0xd422956ba086689:0x50c9273485d0b549!8m2!3d40.4275725!4d-3.6739868!9m1!1b1!16s%2Fg%2F11z0yqvgtg?authuser=0&entry=ttu";
const googleMapsProfileUrl = "https://maps.google.com/?cid=5821227099889907017";
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "";
const googlePlaceQuery = `${businessName}, ${streetAddress}, ${postalCode} ${addressLocality}, Spain`;
const keywords =
  "DJ para eventos Madrid, DJ Madrid, DJ bodas Madrid, DJ eventos corporativos Madrid, DJ fiestas privadas Madrid, sonido e iluminacion Madrid";

const services = [
  {
    eyebrow: "Bodas",
    title: "DJ para bodas en Madrid",
    copy: "Ceremonia, coctel, cena y fiesta con una sesion pensada para acompanar cada tramo del dia.",
    image:
      "https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=900&q=82",
  },
  {
    eyebrow: "Empresa",
    title: "DJ para eventos corporativos",
    copy: "Ambientacion elegante para cenas, presentaciones, networking y celebraciones de equipo en Madrid.",
    image:
      "https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&fit=crop&w=900&q=82",
  },
  {
    eyebrow: "Celebraciones",
    title: "DJ para fiestas privadas",
    copy: "Cumpleanos, comuniones y celebraciones con musica adaptable por edades, energia y estilo.",
    image:
      "https://images.unsplash.com/photo-1505236858219-8359eb29e329?auto=format&fit=crop&w=900&q=82",
  },
];

const steps = [
  "Escuchamos el plan del evento",
  "Preparamos musica y tiempos",
  "Montamos sonido e iluminacion",
  "Cuidamos la pista hasta el cierre",
];

const faqs = [
  {
    question: "Que incluye el servicio de DJ para eventos en Madrid?",
    answer:
      "Incluye preparacion musical, cabina DJ, sonido adaptado al espacio, iluminacion de ambiente y coordinacion de los momentos clave del evento.",
  },
  {
    question: "Trabajais en bodas y eventos de empresa?",
    answer:
      "Si. NIGHTSTAGE cubre bodas, eventos corporativos, fiestas privadas, comuniones, cumpleanos y celebraciones en Madrid y alrededores.",
  },
  {
    question: "Cuanto cuesta contratar un DJ para eventos en Madrid?",
    answer:
      "La base orientativa parte de 300 EUR y se ajusta segun fecha, ubicacion, duracion, aforo y necesidades de sonido e iluminacion.",
  },
  {
    question: "Como puedo consultar disponibilidad?",
    answer:
      `Puedes llamar al ${phone}, escribir a ${email} o enviar la fecha, ubicacion y tipo de evento para recibir una propuesta ajustada.`,
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EntertainmentBusiness",
      "@id": `${siteUrl}#business`,
      name: businessName,
      url: siteUrl,
      image: heroPoster,
      logo: heroPoster,
      description,
      telephone: phoneInternational,
      email,
      priceRange: "Desde 300 EUR",
      address: {
        "@type": "PostalAddress",
        streetAddress,
        addressLocality,
        addressRegion,
        postalCode,
        addressCountry: "ES",
      },
      areaServed: [
        {
          "@type": "City",
          name: "Madrid",
        },
        {
          "@type": "AdministrativeArea",
          name: "Comunidad de Madrid",
        },
      ],
      sameAs: [`https://www.youtube.com/watch?v=${youtubeId}`, googleMapsProfileUrl],
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servicios de DJ para eventos en Madrid",
        itemListElement: services.map((service) => ({
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: service.title,
            areaServed: "Madrid",
            provider: {
              "@id": `${siteUrl}#business`,
            },
            description: service.copy,
          },
        })),
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: `${businessName} - DJ para eventos en Madrid`,
      publisher: {
        "@id": `${siteUrl}#business`,
      },
      inLanguage: "es-ES",
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="ES-MD" />
    <meta name="geo.placename" content="Madrid" />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={businessName} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={heroPoster} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={heroPoster} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <style>
      :root {
        color-scheme: dark;
        --ink: #050505;
        --panel: #101010;
        --panel-soft: #171717;
        --line: #2a2a2a;
        --text: #f7f4ee;
        --muted: #c7c0b7;
        --acid: #23d6c8;
        --teal: #23d6c8;
        --rose: #23d6c8;
        --white: #ffffff;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background: var(--ink);
        color: var(--text);
      }

      body::selection {
        background: var(--acid);
        color: var(--ink);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 20;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(5, 5, 5, 0.72);
        backdrop-filter: blur(16px);
      }

      .nav {
        width: min(1180px, calc(100% - 32px));
        min-height: 72px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        color: var(--text);
      }

      .nightstage-logo {
        display: block;
        overflow: visible;
        color: currentColor;
      }

      .brand-logo {
        width: min(260px, 52vw);
        height: auto;
      }

      .hero-logo {
        width: min(520px, 88vw);
        height: auto;
        margin-bottom: 26px;
        color: rgba(255, 255, 255, 0.92);
        filter: drop-shadow(0 12px 28px rgba(0, 0, 0, 0.5));
      }

      .logo-line {
        stroke: currentColor;
        stroke-width: 3;
        stroke-linecap: square;
      }

      .logo-text {
        fill: currentColor;
        font-family: "Arial Narrow", "Helvetica Neue", Arial, sans-serif;
        font-size: 34px;
        font-weight: 800;
        letter-spacing: 7px;
      }

      .nav-links {
        display: none;
        align-items: center;
        gap: 22px;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .nav-links a:hover {
        color: var(--white);
      }

      .button {
        display: inline-flex;
        min-height: 46px;
        align-items: center;
        justify-content: center;
        border: 1px solid transparent;
        border-radius: 8px;
        padding: 0 18px;
        font-weight: 800;
        letter-spacing: 0;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background 160ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        background: var(--acid);
        color: var(--ink);
      }

      .button.ghost {
        border-color: rgba(255, 255, 255, 0.34);
        background: rgba(0, 0, 0, 0.26);
        color: var(--white);
      }

      .hero {
        min-height: 86svh;
        padding: 116px 0 72px;
        display: grid;
        align-items: end;
        position: relative;
        overflow: hidden;
        isolation: isolate;
        background-image: url("https://img.youtube.com/vi/xnsxllY5VPw/maxresdefault.jpg");
        background-size: cover;
        background-position: center;
      }

      .hero-video {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        border: 0;
        object-fit: cover;
        object-position: center;
        pointer-events: none;
      }

      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background-image:
          linear-gradient(90deg, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.58) 46%, rgba(0, 0, 0, 0.22)),
          linear-gradient(0deg, rgba(5, 5, 5, 0.95), rgba(5, 5, 5, 0.1) 48%);
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background:
          linear-gradient(135deg, rgba(35, 214, 200, 0.22), transparent 34%),
          linear-gradient(310deg, rgba(255, 79, 135, 0.2), transparent 38%);
        mix-blend-mode: screen;
      }

      .shell {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 760px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 18px;
        color: var(--acid);
        font-size: 0.88rem;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 34px;
        height: 2px;
        background: currentColor;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        max-width: 720px;
        font-size: 3.35rem;
        line-height: 0.96;
        letter-spacing: 0;
      }

      .hero-copy {
        max-width: 620px;
        margin-top: 24px;
        color: var(--muted);
        font-size: 1.15rem;
        line-height: 1.7;
      }

      .hero-actions {
        margin-top: 32px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
      }

      .stat {
        min-height: 138px;
        padding: 24px;
        background: var(--panel);
      }

      .stat strong {
        display: block;
        color: var(--white);
        font-size: 2.1rem;
        line-height: 1;
      }

      .stat span {
        display: block;
        margin-top: 10px;
        color: var(--muted);
        line-height: 1.5;
      }

      section {
        padding: 84px 0;
      }

      .section-head {
        display: grid;
        gap: 16px;
        margin-bottom: 38px;
      }

      .section-kicker {
        color: var(--teal);
        font-size: 0.86rem;
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      h2 {
        max-width: 760px;
        font-size: 2.35rem;
        line-height: 1.06;
        letter-spacing: 0;
      }

      .section-head p {
        max-width: 680px;
        color: var(--muted);
        font-size: 1.06rem;
        line-height: 1.75;
      }

      .service-grid {
        display: grid;
        gap: 18px;
      }

      .service-card {
        min-height: 520px;
        display: grid;
        grid-template-rows: 260px 1fr;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
      }

      .service-card figure {
        margin: 0;
        min-height: 0;
      }

      .service-body {
        padding: 24px;
        display: grid;
        align-content: start;
        gap: 14px;
      }

      .tag {
        width: fit-content;
        border: 1px solid rgba(35, 214, 200, 0.55);
        border-radius: 999px;
        padding: 6px 10px;
        color: var(--teal);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0;
      }

      h3 {
        font-size: 1.45rem;
        line-height: 1.16;
        letter-spacing: 0;
      }

      .service-body p,
      .equipment-copy,
      .step p,
      .contact p {
        color: var(--muted);
        line-height: 1.7;
      }

      .equipment {
        background:
          linear-gradient(180deg, var(--panel), var(--ink));
      }

      .equipment-layout {
        display: grid;
        gap: 34px;
        align-items: center;
      }

      .equipment-photo {
        min-height: 420px;
        margin: 0;
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid var(--line);
      }

      .equipment-list {
        display: grid;
        gap: 14px;
        margin-top: 28px;
      }

      .equipment-item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 14px;
        align-items: start;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.035);
      }

      .check {
        width: 28px;
        height: 28px;
        display: grid;
        place-items: center;
        border-radius: 6px;
        background: var(--rose);
        color: var(--white);
        font-weight: 900;
      }

      .equipment-item strong {
        display: block;
        margin-bottom: 6px;
      }

      .process {
        background: var(--panel-soft);
      }

      .steps {
        display: grid;
        gap: 1px;
        background: var(--line);
      }

      .step {
        min-height: 180px;
        padding: 24px;
        background: var(--panel-soft);
      }

      .step-number {
        display: inline-grid;
        width: 42px;
        height: 42px;
        place-items: center;
        margin-bottom: 26px;
        border-radius: 8px;
        background: var(--teal);
        color: var(--ink);
        font-weight: 900;
      }

      .local-seo {
        background: var(--ink);
      }

      .seo-points,
      .faq-list {
        display: grid;
        gap: 14px;
      }

      .seo-points {
        margin-top: 30px;
      }

      .seo-point,
      .faq-item {
        padding: 22px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.035);
      }

      .seo-point strong,
      .faq-item h3 {
        display: block;
        margin-bottom: 8px;
      }

      .seo-point p,
      .faq-item p {
        color: var(--muted);
        line-height: 1.7;
      }

      .reviews {
        background:
          linear-gradient(180deg, var(--ink), var(--panel-soft));
      }

      .reviews-panel {
        display: grid;
        gap: 22px;
        padding: 22px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.035);
      }

      .reviews-header {
        display: grid;
        gap: 18px;
        align-items: center;
      }

      .google-summary {
        display: grid;
        gap: 8px;
      }

      .google-name {
        color: var(--white);
        font-weight: 900;
        text-decoration: none;
      }

      .google-name:hover {
        color: var(--teal);
      }

      .reviews-note {
        color: var(--muted);
        line-height: 1.65;
      }

      .reviews-rating {
        width: fit-content;
        border: 1px solid rgba(35, 214, 200, 0.55);
        border-radius: 999px;
        padding: 6px 10px;
        color: var(--teal);
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .review-source {
        width: fit-content;
        border: 1px solid rgba(251, 188, 4, 0.55);
        border-radius: 999px;
        padding: 6px 10px;
        color: #fbbc04;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .powered-by-google {
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 800;
      }

      .google-blue {
        color: #4285f4;
      }

      .google-red {
        color: #ea4335;
      }

      .google-yellow {
        color: #fbbc04;
      }

      .google-green {
        color: #34a853;
      }

      .reviews-track {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: minmax(260px, 1fr);
        gap: 14px;
        overflow-x: auto;
        padding-bottom: 8px;
        scroll-snap-type: x proximity;
      }

      .review-card {
        min-height: 230px;
        display: grid;
        align-content: start;
        gap: 16px;
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 8px;
        background: var(--panel);
        scroll-snap-align: start;
      }

      .review-author {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        align-items: center;
      }

      .review-avatar {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: var(--teal);
        color: var(--ink);
        font-weight: 900;
      }

      .review-avatar img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        border-radius: inherit;
      }

      .review-author strong,
      .review-author span {
        display: block;
      }

      .review-author span {
        margin-top: 4px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .review-card p {
        color: var(--muted);
        line-height: 1.7;
      }

      .review-card.is-loading,
      .review-card.is-empty {
        min-height: 160px;
      }

      .faq {
        background: var(--panel-soft);
      }

      .contact {
        position: relative;
        overflow: hidden;
        background-image:
          linear-gradient(90deg, rgba(5, 5, 5, 0.94), rgba(5, 5, 5, 0.74)),
          url("https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?auto=format&fit=crop&w=1800&q=82");
        background-position: center;
        background-size: cover;
      }

      .contact-layout {
        display: grid;
        gap: 34px;
        align-items: start;
      }

      .contact h2 {
        max-width: 660px;
      }

      .contact-panel {
        display: grid;
        gap: 16px;
        padding: 24px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        background: rgba(0, 0, 0, 0.48);
      }

      .contact-row {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.18);
      }

      .contact-row:last-child {
        padding-bottom: 0;
        border-bottom: 0;
      }

      .contact-row span {
        color: var(--muted);
      }

      .contact-row strong {
        text-align: right;
      }

      .site-footer {
        padding: 28px 0;
        border-top: 1px solid var(--line);
        background: var(--ink);
        color: var(--muted);
      }

      .footer-inner {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        font-size: 0.92rem;
      }

      .footer-copy {
        color: var(--text);
        font-weight: 800;
      }

      .footer-credit {
        color: var(--muted);
      }

      .footer-inner a {
        color: var(--text);
        font-weight: 800;
        text-decoration: underline;
        text-decoration-color: rgba(35, 214, 200, 0.55);
        text-underline-offset: 4px;
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-video {
          display: none;
        }
      }

      @media (min-width: 720px) {
        .nav-links {
          display: flex;
        }

        .stats {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .service-grid,
        .steps,
        .seo-points,
        .reviews-header,
        .faq-list {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .reviews-header .button {
          justify-self: end;
        }
      }

      @media (min-width: 960px) {
        .hero {
          min-height: 84svh;
        }

        h1 {
          font-size: 5.6rem;
        }

        h2 {
          font-size: 3.2rem;
        }

        .service-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .equipment-layout,
        .contact-layout {
          grid-template-columns: 1fr 0.82fr;
        }

        .steps {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }
      }

      @media (max-width: 719px) {
        .nav {
          min-height: 66px;
        }

        .nav .button {
          min-height: 40px;
          padding: 0 12px;
          font-size: 0.88rem;
        }

        .hero {
          min-height: 88svh;
          padding-top: 98px;
        }

        h1 {
          font-size: 2.65rem;
        }

        h2 {
          font-size: 2rem;
        }

        .hero-copy {
          font-size: 1.03rem;
        }

        .hero-actions .button {
          width: 100%;
        }

        .nav .button {
          width: auto;
        }

        .brand-logo {
          width: min(210px, 46vw);
        }

        .hero-logo {
          width: min(360px, 88vw);
          margin-bottom: 22px;
        }

        .service-card {
          min-height: 480px;
        }

        .equipment-photo {
          min-height: 320px;
        }

        .contact-row {
          display: grid;
        }

        .contact-row strong {
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Principal">
        <a class="brand" href="#inicio" aria-label="NIGHTSTAGE inicio">
          <svg class="nightstage-logo brand-logo" viewBox="0 0 520 58" role="img" aria-label="NIGHT STAGE">
            <line class="logo-line" x1="0" y1="29" x2="78" y2="29"></line>
            <text class="logo-text" x="260" y="39" text-anchor="middle">NIGHT STAGE</text>
            <line class="logo-line" x1="442" y1="29" x2="520" y2="29"></line>
          </svg>
        </a>
        <div class="nav-links" aria-label="Secciones">
          <a href="#servicios">Servicios</a>
          <a href="#equipo">Equipo</a>
          <a href="#resenas">Resenas</a>
          <a href="#proceso">Proceso</a>
        </div>
        <a class="button primary" href="#contacto">Pedir fecha</a>
      </nav>
    </header>

    <main id="inicio">
      <section class="hero" aria-label="DJ para eventos en Madrid">
        <video
          class="hero-video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={heroPoster}
          aria-hidden="true"
        >
          <source src={heroVideoWebm} type="video/webm" media="(min-width: 900px)" />
          <source src={heroVideoMp4} type="video/mp4" />
        </video>
        <div class="shell hero-content">
          <svg class="nightstage-logo hero-logo" viewBox="0 0 520 58" aria-hidden="true">
            <line class="logo-line" x1="0" y1="29" x2="78" y2="29"></line>
            <text class="logo-text" x="260" y="39" text-anchor="middle">NIGHT STAGE</text>
            <line class="logo-line" x1="442" y1="29" x2="520" y2="29"></line>
          </svg>
          <p class="eyebrow">DJ profesional para eventos en Madrid</p>
          <h1>DJ para eventos en Madrid con sonido e iluminacion profesional.</h1>
          <p class="hero-copy">
            NIGHTSTAGE crea sesiones para bodas, empresas y celebraciones privadas
            con cabina DJ, sonido potente, iluminacion cuidada y lectura real de la sala.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#contacto">Consultar disponibilidad</a>
            <a class="button ghost" href="#servicios">Ver servicios</a>
          </div>
        </div>
      </section>

      <aside class="stats" aria-label="Datos destacados">
        <div class="stat">
          <strong>DJ</strong>
          <span>para eventos en Madrid</span>
        </div>
        <div class="stat">
          <strong>Madrid</strong>
          <span>servicio en ciudad y alrededores</span>
        </div>
        <div class="stat">
          <strong>300 EUR</strong>
          <span>base orientativa de presupuesto</span>
        </div>
        <div class="stat">
          <strong>Live</strong>
          <span>musica, sonido, luces y montaje</span>
        </div>
      </aside>

      <section id="servicios">
        <div class="shell">
          <div class="section-head">
            <span class="section-kicker">Eventos</span>
            <h2>Servicios de DJ para eventos en Madrid y alrededores.</h2>
            <p>
              Elegimos la musica con el plan sobre la mesa: horarios, invitados,
              momentos clave y el punto exacto en el que la pista tiene que despegar.
            </p>
          </div>

          <div class="service-grid">
            {
              services.map((service) => (
                <article class="service-card">
                  <figure>
                    <img src={service.image} alt={service.title} loading="lazy" />
                  </figure>
                  <div class="service-body">
                    <span class="tag">{service.eyebrow}</span>
                    <h3>{service.title}</h3>
                    <p>{service.copy}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="local-seo" id="dj-para-eventos-madrid">
        <div class="shell">
          <div class="section-head">
            <span class="section-kicker">Madrid</span>
            <h2>DJ para eventos en Madrid con montaje cuidado de principio a fin.</h2>
            <p>
              Trabajamos en Madrid capital y alrededores para bodas, eventos de empresa,
              fiestas privadas, comuniones y celebraciones que necesitan musica, sonido
              e iluminacion profesional sin complicaciones.
            </p>
          </div>
          <div class="seo-points">
            <article class="seo-point">
              <strong>Servicio local en Madrid</strong>
              <p>Atendemos eventos en Salamanca, centro de Madrid, fincas, hoteles, restaurantes y espacios privados de la Comunidad de Madrid.</p>
            </article>
            <article class="seo-point">
              <strong>Musica adaptada al publico</strong>
              <p>Preparamos estilos, momentos clave y transiciones para mantener la energia correcta durante coctel, cena, baile y cierre.</p>
            </article>
            <article class="seo-point">
              <strong>Sonido e iluminacion profesional</strong>
              <p>Dimensionamos el equipo segun aforo, espacio y horario para que el evento suene claro y tenga presencia visual.</p>
            </article>
            <article class="seo-point">
              <strong>Contacto directo</strong>
              <p>Consulta disponibilidad por telefono o correo con fecha, lugar, numero de invitados y tipo de evento.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="equipment" id="equipo">
        <div class="shell equipment-layout">
          <div>
            <div class="section-head">
              <span class="section-kicker">Sonido e iluminacion</span>
              <h2>Montaje limpio, cabina preparada y una sala que respira musica.</h2>
              <p>
                Equipo profesional para espacios privados, fincas, hoteles y salas
                de empresa en Madrid y alrededores.
              </p>
            </div>
            <div class="equipment-list">
              <div class="equipment-item">
                <span class="check">1</span>
                <div>
                  <strong>Control DJ profesional</strong>
                  <p>Mezcla precisa para adaptar estilos, edades y momentos sin cortes bruscos.</p>
                </div>
              </div>
              <div class="equipment-item">
                <span class="check">2</span>
                <div>
                  <strong>Sonido dimensionado</strong>
                  <p>Potencia ajustada al aforo para mantener claridad en coctel, cena y baile.</p>
                </div>
              </div>
              <div class="equipment-item">
                <span class="check">3</span>
                <div>
                  <strong>Iluminacion de ambiente</strong>
                  <p>Escenas de color para entrada, primer baile, fiesta y cierre.</p>
                </div>
              </div>
            </div>
          </div>

          <figure class="equipment-photo">
            <img
              src="https://images.unsplash.com/photo-1571266028243-d220c6a7edbf?auto=format&fit=crop&w=1200&q=82"
              alt="Cabina DJ profesional con luces"
              loading="lazy"
            />
          </figure>
        </div>
      </section>

      <section class="process" id="proceso">
        <div class="shell">
          <div class="section-head">
            <span class="section-kicker">Como trabajamos</span>
            <h2>Todo queda claro antes de que suene el primer tema.</h2>
          </div>
          <div class="steps">
            {
              steps.map((step, index) => (
                <article class="step">
                  <span class="step-number">{String(index + 1).padStart(2, "0")}</span>
                  <h3>{step}</h3>
                  <p>
                    Agenda, estilo y necesidades tecnicas se preparan con antelacion.
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="reviews" id="resenas">
        <div class="shell">
          <div class="section-head">
            <span class="section-kicker">Resenas</span>
            <h2>Opiniones reales de NIGHT STAGE en Google.</h2>
            <p>
              Las valoraciones se consultan en el perfil publico de Google Maps para
              ver la informacion actualizada antes de reservar.
            </p>
          </div>

          <div class="reviews-panel">
            <div class="reviews-header">
              <div class="google-summary">
                <a class="google-name" href={googleMapsReviewsUrl} target="_blank" rel="nofollow noopener">
                  NIGHT STAGE en Google
                </a>
                <span class="reviews-rating" data-google-rating>Google Maps</span>
                <span class="reviews-note" data-google-review-count>Resenas verificadas en Google Maps.</span>
                <span class="powered-by-google" aria-label="Powered by Google">
                  powered by
                  <span class="google-blue">G</span><span class="google-red">o</span><span class="google-yellow">o</span><span class="google-blue">g</span><span class="google-green">l</span><span class="google-red">e</span>
                </span>
              </div>
              <a class="button primary" href={googleMapsReviewsUrl} target="_blank" rel="nofollow noopener">
                Ver resenas en Google
              </a>
            </div>

            <div class="reviews-track" aria-label="Resenas de Google" data-google-reviews>
              <article class="review-card is-loading" data-review-placeholder>
                <div class="review-author">
                  <span class="review-avatar">G</span>
                  <div>
                    <strong>Resenas de Google</strong>
                    <span data-google-reviews-status>
                      {googleMapsApiKey ? "Cargando resenas reales..." : "Resenas verificadas en Google"}
                    </span>
                  </div>
                </div>
                <span class="review-source">Google Maps</span>
                <p>
                  {googleMapsApiKey
                    ? "Estamos cargando las opiniones verificadas de NIGHT STAGE desde Google."
                    : "Las opiniones se muestran desde el perfil oficial de NIGHT STAGE en Google Maps."}
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="faq" id="preguntas-frecuentes">
        <div class="shell">
          <div class="section-head">
            <span class="section-kicker">Preguntas frecuentes</span>
            <h2>Contratar DJ para eventos en Madrid.</h2>
          </div>
          <div class="faq-list">
            {
              faqs.map((faq) => (
                <article class="faq-item">
                  <h3>{faq.question}</h3>
                  <p>{faq.answer}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="contact" id="contacto">
        <div class="shell contact-layout">
          <div>
            <p class="eyebrow">Presupuesto y disponibilidad</p>
            <h2>Cuentanos fecha, lugar y tipo de evento.</h2>
            <p>
              Recibiras una propuesta ajustada al espacio, horarios y formato de la
              celebracion.
            </p>
            <div class="hero-actions">
              <a class="button primary" href={phoneHref}>Llamar ahora</a>
              <a class="button ghost" href={emailHref}>Contacto por correo</a>
            </div>
          </div>

          <div class="contact-panel" aria-label="Informacion de contacto">
            <div class="contact-row">
              <span>Zona</span>
              <strong>Madrid y alrededores</strong>
            </div>
            <div class="contact-row">
              <span>Servicios</span>
              <strong>Bodas, empresa y celebraciones</strong>
            </div>
            <div class="contact-row">
              <span>Desde</span>
              <strong>300 EUR segun fecha y montaje</strong>
            </div>
            <div class="contact-row">
              <span>Telefono</span>
              <strong><a href={phoneHref}>{phone}</a></strong>
            </div>
            <div class="contact-row">
              <span>Direccion</span>
              <strong>{address}</strong>
            </div>
            <div class="contact-row">
              <span>Email</span>
              <strong><a href={emailHref}>{email}</a></strong>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-copy">Copyright {year} NIGHTSTAGE. Todos los derechos reservados.</span>
        <span class="footer-credit">
          Desarrollo web:
          <a href="https://www.mlabsmusic.com/" target="_blank" rel="noreferrer">M Labs Music</a>
        </span>
      </div>
    </footer>
    <script
      is:inline
      set:html={`window.nightstageGoogleReviews = ${JSON.stringify({
        hasApiKey: Boolean(googleMapsApiKey),
        query: googlePlaceQuery,
        reviewsUrl: googleMapsReviewsUrl,
      })};`}
    ></script>
    <script is:inline>
      (() => {
        const config = window.nightstageGoogleReviews || {};
        const track = document.querySelector("[data-google-reviews]");
        const ratingEl = document.querySelector("[data-google-rating]");
        const countEl = document.querySelector("[data-google-review-count]");
        const statusEl = document.querySelector("[data-google-reviews-status]");

        const setStatus = (message) => {
          if (statusEl) {
            statusEl.textContent = message;
          }
        };

        const renderEmpty = (message) => {
          if (!track) {
            return;
          }

          track.replaceChildren(createEmptyCard(message));
        };

        const createEmptyCard = (message) => {
          const article = document.createElement("article");
          article.className = "review-card is-empty";

          const author = document.createElement("div");
          author.className = "review-author";

          const avatar = document.createElement("span");
          avatar.className = "review-avatar";
          avatar.textContent = "G";

          const copy = document.createElement("div");
          const title = document.createElement("strong");
          title.textContent = "Resenas de Google";
          const meta = document.createElement("span");
          meta.textContent = "Google Maps";

          copy.append(title, meta);
          author.append(avatar, copy);

          const source = document.createElement("span");
          source.className = "review-source";
          source.textContent = "Google Maps";

          const text = document.createElement("p");
          text.textContent = message;

          article.append(author, source, text);
          return article;
        };

        const createReviewCard = (review) => {
          const article = document.createElement("article");
          article.className = "review-card";

          const author = document.createElement("div");
          author.className = "review-author";

          const avatar = document.createElement("span");
          avatar.className = "review-avatar";

          if (review.profile_photo_url) {
            const photo = document.createElement("img");
            photo.src = review.profile_photo_url;
            photo.alt = "";
            photo.loading = "lazy";
            photo.referrerPolicy = "no-referrer";
            avatar.append(photo);
          } else {
            avatar.textContent = (review.author_name || "G").trim().charAt(0).toUpperCase();
          }

          const copy = document.createElement("div");
          const name = document.createElement("strong");
          name.textContent = review.author_name || "Cliente de Google";
          const meta = document.createElement("span");
          meta.textContent = review.relative_time_description || "Resena de Google";

          copy.append(name, meta);
          author.append(avatar, copy);

          const source = document.createElement("span");
          source.className = "review-source";
          source.textContent = `${Number(review.rating || 5).toFixed(0)}/5 en Google`;

          const text = document.createElement("p");
          text.textContent = review.text || "Valoracion publicada en Google.";

          article.append(author, source, text);
          return article;
        };

        const renderReviews = (place) => {
          if (ratingEl && place.rating) {
            ratingEl.textContent = `${Number(place.rating).toFixed(1)} de 5 en Google`;
          }

          if (countEl) {
            countEl.textContent = place.user_ratings_total
              ? `${place.user_ratings_total} resenas verificadas en Google Maps.`
              : "Resenas verificadas en Google Maps.";
          }

          const reviews = Array.isArray(place.reviews) ? place.reviews.filter((review) => review.text) : [];

          if (!reviews.length) {
            renderEmpty("Google no ha devuelto resenas con texto para mostrar en la web.");
            return;
          }

          track.replaceChildren(...reviews.slice(0, 5).map(createReviewCard));
        };

        window.initGoogleReviews = () => {
          if (!track || !window.google?.maps?.places) {
            renderEmpty("No se pudo cargar Google Places para mostrar las resenas.");
            return;
          }

          const service = new google.maps.places.PlacesService(document.createElement("div"));

          service.findPlaceFromQuery(
            {
              query: config.query,
              fields: ["place_id"],
            },
            (results, status) => {
              if (status !== google.maps.places.PlacesServiceStatus.OK || !results?.[0]?.place_id) {
                renderEmpty("No se encontro el perfil de NIGHT STAGE en Google Places.");
                return;
              }

              service.getDetails(
                {
                  placeId: results[0].place_id,
                  fields: ["name", "rating", "user_ratings_total", "reviews", "url"],
                },
                (place, detailsStatus) => {
                  if (detailsStatus !== google.maps.places.PlacesServiceStatus.OK || !place) {
                    renderEmpty("Google no devolvio resenas para mostrar en la web.");
                    return;
                  }

                  renderReviews(place);
                },
              );
            },
          );
        };

        if (!config.hasApiKey) {
          setStatus("Resenas verificadas en Google");
        }
      })();
    </script>
    {
      googleMapsApiKey && (
        <script
          is:inline
          src={`https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&libraries=places&callback=initGoogleReviews`}
          async
          defer
        ></script>
      )
    }
  </body>
</html>
